{
  "name": "api-test-harness",
  "private": true,
  "version": "1.0.296",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:info": "node ./scripts/build/increment-version.mjs --no-increment",
    "build": "npm run lint && npm run build:info && vite build",
    "build:clean": "npm run clean && npm run build",
    "typecheck": "tsc -b",
    "verify": "npm run typecheck && npm run build",
    "build:full": "npm run clean && npm run verify",
    "version:bump": "node ./scripts/build/increment-version.mjs --increment",
    "build:release": "npm run version:bump && npm run build:full",
    "clean": "rimraf dist dist-ssr build out .vite tsconfig.tsbuildinfo",
    "clean:full": "npm run clean && rimraf node_modules package-lock.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "echo \"No tests configured - lightweight API development tool\"",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@microsoft/applicationinsights-react-js": "^19.4.0",
    "@microsoft/applicationinsights-web": "^3.4.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.100.11",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^4.3.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "eslint-plugin-react-hooks": {
      "eslint": "^10.0.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "~7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13"
  }
}
